{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "capubridge",
  "version": "0.1.0",
  "identifier": "com.capubridge.io",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173/",
    "beforeDevCommand": "vp dev",
    "beforeBuildCommand": "vp build"
  },
  "app": {
    "windows": [
      {
        "title": "capubridge",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": ["resources"],
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
